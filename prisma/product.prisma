model Product {
  id          String @id @default(uuid())
  title       String
  description String
  price       Float
  stock       Int
  imageUrl    String

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
}
